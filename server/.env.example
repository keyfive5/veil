# Veil managed-key proxy + license backend — copy to .env and fill in.
# NEVER commit the real .env.

# --- AI keys (held only here, never shipped in the app) ---
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# --- Public URL of THIS server (used to build magic links) ---
APP_PUBLIC_URL=https://your-veil-server.example.com

# --- Stripe (managed/no-key tier) ---
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Map your Stripe price IDs → plans (set these to YOUR price IDs):
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_LIFETIME=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- Free tier: runs on the free Groq AI ($0 to you). Needs GROQ_API_KEY above. ---
CAP_FREE=500
# Groq model for the free tier (must support vision/images). Override if needed:
FREE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Per-plan monthly request caps (cost guard + upsell trigger) ---
CAP_PRO=8000
CAP_LIFETIME=8000
CAP_ENTERPRISE=200000

# --- SQLite location (use a PERSISTENT volume on your host) ---
DB_PATH=./veil.db

# --- Local-testing only (leave OFF in production) ---
# VEIL_LICENSES=VEIL-DEMO-1234     # static keys accepted without Stripe
# DEV_ACCEPT_ANY=1                 # accept ANY non-empty key (dev only!)
VEIL_MONTHLY_CAP=8000

PORT=8787
