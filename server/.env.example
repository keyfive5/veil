# Veil managed-key proxy — copy to .env and fill in. NEVER commit the real .env.

# The real Claude key (held only here, never shipped in the app)
ANTHROPIC_API_KEY=sk-ant-...

# Transcription for Listen mode (one of these). Groq is free + fast.
GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# License keys you issue to paying customers (comma-separated).
# Leave blank in dev to accept any non-empty key. Lock this down in production.
VEIL_LICENSES=VEIL-DEMO-1234,VEIL-ACME-5678

# Rough monthly request cap per license (cost guard + upsell trigger).
VEIL_MONTHLY_CAP=8000

# Port
PORT=8787
